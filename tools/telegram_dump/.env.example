# https://my.telegram.org → API development tools → api_id / api_hash
TG_API_ID=
TG_API_HASH=
TG_PHONE=+79001234567
# @username, t.me/..., или числовой id чата
TG_CHAT=
# 0 = все сообщения; для пробы поставьте 100
TG_LIMIT=0
# Пароль облачного пароля Telegram (2FA), если включён
TG_PASSWORD_2FA=

# База API: с ПК часто удобнее через веб-прокси (порт 8080 + /api)
# ASSISTANT_API_BASE=http://ВАШ_IP:8080/api
ASSISTANT_API_BASE=http://127.0.0.1:8000
ASSISTANT_API_TOKEN=owner-dev-token
PREFERRED_CASE_NUMBER=

TG_DOWNLOAD_DIR=./downloads/telegram
TG_SESSION_DIR=./sessions

# 1 = также выгружать фото из чата как файлы (по умолчанию только «документы»)
TG_INCLUDE_PHOTOS=0
# 1 = обход сообщений от старых к новым
TG_FROM_OLDEST=0
# Пауза между POST в API (сек)
TG_UPLOAD_DELAY_SEC=0.35
# Пропускать файлы больше N мегабайт (пусто = без лимита)
# TG_MAX_FILE_MB=80
# 0 = только скачать, не слать в API
TG_UPLOAD=1
