# Шаблон переменных окружения (в репозитории файл называется env.example — без точки в начале).
# Локальный файл .env.example в git не отслеживается: на сервере можно держать свою копию-справочник без конфликтов при git pull.
# Скопируйте: cp env.example .env и заполните секреты. Деплой не затирает .env и .env.local.
# Секреты удобно держать в .env.local (см. .env.local.example); иначе всё в одном .env — тоже ок.
# В compose: веб снаружи :8080. API снаружи — HOST_API_PORT (по умолчанию 8000), внутри контейнера API всегда 8000.
# Если при docker compose ошибка «port 8000 already allocated» — в .env: HOST_API_PORT=8001 и запускайте compose
# с явным --env-file .env из КОРНЯ репо, иначе подстановка порта не сработает:
#   docker compose --env-file .env -f infra/compose.prod.yml up -d --build api
# Не оставляйте строки APP_PORT= или WEB_PORT= без значения — их удалит infra/ensure_env.sh.
APP_ENV=development
APP_PORT=8000
HOST_API_PORT=8000
WEB_PORT=8080

POSTGRES_DB=my_assistant
POSTGRES_USER=my_assistant
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=case-files

OPENAI_API_KEY=
# OpenAI: https://api.openai.com/v1  |  OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
# Для OpenRouter укажи модель с префиксом, например: openai/gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# Опционально (OpenRouter рекомендует Referer)
LLM_HTTP_REFERER=
LLM_APP_TITLE=My Assistant
# Часть команд через LLM + tools (см. apps/api/app/chat_tools.py). Отключить: CHAT_TOOLS_ROUTER=0
CHAT_TOOLS_ROUTER=
# Автосводка длинных сообщений в чат по делу (переписка юристов). Отключить: CASE_NOTE_DIGEST=0
CASE_NOTE_DIGEST=
OWNER_TOKEN=owner-dev-token
MEMBER_TOKEN=member-dev-token
COURT_SYNC_ENABLED=true
COURT_SYNC_NIGHT_HOUR=2
COURT_SYNC_MAX_DOCS_PER_RUN=200
COURT_SYNC_DELAY_SEC=5
COURT_SYNC_TIMEOUT_SEC=120

# Parser-API (kad.arbitr.ru): https://www.parser-api.com/kad-arbitr-ru#documentation
# Текст: https://parser-api.com/documentation/arbitr-api.txt
# OpenAPI: https://parser-api.com/documentation/openapi/kad-arbitr-openapi.yaml
# Лимит/расход JSON: https://parser-api.com/stat/?key=ВАШ_КЛЮЧ — в приложении: GET /internal/parser-api/usage
# Статус: https://parser-api.com/status/?format=json — в приложении: GET /internal/parser-api/service-status
# Бот: https://t.me/parser_api_bot | Рекомендуют ограничить IP доступа к ключу (письмом провайдеру).
PARSER_API_KEY=
PARSER_API_BASE_URL=https://parser-api.com/parser/arbitr_api
PARSER_API_TIMEOUT_SEC=120
# Сколько раз повторять parser pdf_download при сбое (сеть / лимит), по умолчанию 3.
PARSER_PDF_DOWNLOAD_RETRIES=3
# Воркер: скачивание дел через Parser-API вместо браузера (true/false). Пусто = включено, если задан PARSER_API_KEY.
COURT_SYNC_USE_PARSER_API=
# Если pdf_download у Parser-API вернул ошибку — повторить скачивание через Playwright (true/false). Пусто = true.
PARSER_PDF_FALLBACK_BROWSER=
# Воркер (только Parser-API): дефолтный фильтр по датам, если в задаче из чата не указан год (см. «за 2026» в сообщении).
# Пусто = качать все PDF из ответа. Задача из чата с периодом важнее этих переменных.
PARSER_DOWNLOAD_YEAR_MIN=
PARSER_DOWNLOAD_YEAR_MAX=
PARSER_DOWNLOAD_DATE_FROM=
PARSER_DOWNLOAD_DATE_TO=
